# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code local settings (may contain secrets)
.claude/settings.local.json
.claude/worktrees/

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# supabase local runtime
supabase/.branches/
supabase/.temp/
supabase/snippets/

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local/generated artifacts
lint_out.txt
teste.py
qrcode_drive.png
supabase/migrations/*.disabled
